<% layout('/layouts/boilerplate') -%>

  <body>
    <div class="row justify-content-center container mt-4">
      <div class="card col-lg-7 col-md-7 mb-3">
        <img src="<%= list.image.url %>" class="card-img-top" alt="Listing Image" id="showandeditimg">
        <div class="card-body">
          <h3 class="card-title mb-3">
            <%= list.title %>
          </h3>
          <p class="card-text">
            <%= list.description %>
          </p>
          <h5 class="price">Price: &#8377;<%= list.price.toLocaleString("en-IN") %> <span>/night</span>
          </h5>
          <p class="location">Location: <%= list.location %>, <%= list.country %>
          </p>
          <p class="category">Type: <%= list.category %>
          </p>
          <div class="card-btns mt-4">
            <a class="btn btn-primary" href="#" role="button">Rent Now</a>
          </div>

          <ul class="details-list list-unstyled mt-3">
            <li>🏠 Type: Apartment / House / PG (use your DB field)</li>
            <li>🛏️ Bedrooms: 2</li>
            <li>🛁 Bathrooms: 1</li>
            <li>📏 Area: 1200 sq ft</li>
          </ul>

          <div class="d-flex flex-column flex-md-row justify-content-between gap-2 mt-3">

            <div class="d-flex w-md-50 gap-2">
              <form action="/listings/<%=list._id%>/edit" method="get" class="w-50">
                <button type="submit" class="btn btn-outline-warning w-100">Edit</button>
              </form>

              <form action="/listings/<%=list._id%>?_method=DELETE" method="post"
                onsubmit="return confirm('Are you Sure you want to Delete?')" class="w-50">
                <button type="submit" class="btn btn-outline-danger w-md-100">Delete</button>
              </form>
            </div>


            <div class="mt-2 mt-md-0">
              <a class="btn btn-outline-secondary w-100" href="/listings" role="button">
                Back to Listings
              </a>
            </div>
          </div>




        </div>
      </div>
      <hr>
      <div class="card col-lg-9 col-md-7 mb-3">
        <div class="card-body">
          <h4 class="card-title mb-3">Reviews</h4>

          <!-- Review Form -->
          <div id="reviewForm">
            <form action="/listings/<%= list._id %>/reviews" method="POST" class="needs-validation" novalidate>

              <div class="row g-3 align-items-end">

                <!-- Rating -->

                <!-- Comment -->
                <div class="col-12 col-md-7">
                  <div class="col-12 col-md-3">
                    <label class="form-label small">Rating</label>
                    <select name="review[rating]" class="form-select form-select-sm" required>
                      <option value="" disabled selected>⭐ Select</option>
                      <option value="1">1 ⭐</option>
                      <option value="2">2 ⭐⭐</option>
                      <option value="3">3 ⭐⭐⭐</option>
                      <option value="4">4 ⭐⭐⭐⭐</option>
                      <option value="5">5 ⭐⭐⭐⭐⭐</option>
                    </select>
                    <div class="invalid-feedback">
                      Select rating
                    </div>
                  </div>
                  <label class="form-label small">Comment</label>
                  <textarea name="review[comment]" class="form-control form-control-sm" rows="4"
                    placeholder="Write something..." required></textarea>
                  <div class="invalid-feedback">
                    Comment required
                  </div>
                </div>

                <!-- Button -->
                <div class="col-12 col-md-2 d-grid">
                  <button type="submit" class="btn btn-danger btn-sm">
                    Post
                  </button>
                </div>

              </div>
            </form>
          </div>

          <!-- Reviews List -->
          <div id="reviewsList" class="mt-4">

            <% if (list.reviews.length===0) { %>
              <p class="text-muted">No reviews yet. Be the first to review!</p>
              <% } else { %>

                <div class="row">

                  <% list.reviews.forEach(review=> { %>

                    <div class="col-12 col-md-6 col-lg-4 mb-4">
                      <div class="card h-100 shadow-sm">
                        <div class="card-body">

                          <h5>
                            <%= review.author || "Anonymous" %>
                          </h5>

                          <h6 class="card-subtitle mb-2 text-warning">
                            <%= "⭐" .repeat(review.rating) %>
                          </h6>

                          <p class="card-text">
                            <%= review.comment %>
                          </p>

                          <small class="text-muted">
                            Posted on :
                            <%= review.createdAt ? review.createdAt.toDateString() : "" %>
                          </small>

                        </div>
                      </div>
                    </div>

                    <% }) %>

                </div>

                <% } %>

          </div>
        </div>
      </div>
    </div>     
  </body>