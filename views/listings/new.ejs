<% layout('/layouts/boilerplate') -%>

    <body>
        <div class="container mt-3">
            <div class="row justify-content-center">
                <div class="col-lg-6 col-md-8 mb-3">

                    <div class="card shadow-sm">
                        <div class="card-header">
                            <h3 class="mb-0">Add New Listing</h3>
                        </div>

                        <div class="card-body">

                            <form action="/listings" method="POST" enctype="multipart/form-data" novalidate
                                class="needs-validation">

                                <div class="mb-3">
                                    <label for="title" class="form-label">Title</label>
                                    <input type="text" class="form-control" id="title" name="listing[title]" required>
                                </div>

                                <div class="mb-3">
                                    <label for="description" class="form-label">Description</label>
                                    <textarea class="form-control" id="description" name="listing[description]" rows="3"
                                        required></textarea>
                                </div>

                                <div class="mb-3">
                                    <label for="category" class="form-label">Category</label>
                                    <select class="form-select" id="category" name="listing[category]" required>
                                        <option value="">Choose a category...</option>
                                        <option>Rooms</option>
                                        <option>Beachfront</option>
                                        <option>Pools</option>
                                        <option>Boat House</option>
                                        <option>Castles</option>
                                        <option>Golfing</option>
                                        <option>Iconic Cities</option>
                                        <option>Palaces</option>
                                    </select>
                                </div>

                                <div class="row">

                                    <div class="col-md-4 mb-3">
                                        <label for="price" class="form-label">Price</label>
                                        <input type="number" class="form-control" id="price" name="listing[price]"
                                            required>
                                    </div>

                                    <div class="col-md-8 mb-3">
                                        <label for="location" class="form-label">Location</label>
                                        <input type="text" class="form-control" id="location" name="listing[location]"
                                            required>
                                    </div>

                                </div>

                                <div class="mb-3">
                                    <label for="country" class="form-label">Country</label>
                                    <input type="text" class="form-control" id="country" name="listing[country]"
                                        required>
                                </div>

                                <div class="mb-3">
                                    <!-- changes here for file upload are type and name attribute. enctype is set in the form tag -->
                                    <label for="image" class="form-label">Upload Image</label>
                                    <input type="file" class="form-control" id="image" name="image">
                                </div>

                                <div class="d-flex justify-content-between mt-4">
                                    <button type="submit" class="btn btn-danger">Add</button>
                                    <a href="/listings" class="btn btn-secondary">Cancel</a>
                                </div>

                            </form>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </body>