<% layout('/layouts/boilerplate') -%>

    <style>
        .page-wrapper {
            margin-top: 40px;
            margin-bottom: 60px;
        }

        /* CARD STYLE */

        .card {
            border: none;
            border-radius: 36px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }

        .card-header {
            background: #ff385c;
            color: white;
            font-weight: 600;
            border-top-left-radius: 36px;
            border-top-right-radius: 36px;
            padding: 16px 22px;
        }

        /* INPUTS */

        .form-control,
        .form-select {
            border-radius: 12px;
            padding: 11px;
        }

        .input-group-text {
            background: white;
            border-radius: 12px 0 0 12px;
        }

        /* LABEL */

        label {
            font-weight: 600;
            color: #555;
            margin-bottom: 6px;
        }

        /* BUTTONS */

        .btn-danger {
            background: #ff385c;
            border: none;
        }

        .btn-danger:hover {
            background: #e61e4d;
        }
    </style>


    <div class="container page-wrapper">

        <div class="row justify-content-center">

            <!-- SMALLER WIDTH -->
            <div class="col-lg-5 col-md-7">

                <div class="card">

                    <div class="card-header">
                        <h4 class="mb-0">
                            <i class="bi bi-plus-circle me-2"></i>
                            Add New Listing
                        </h4>
                    </div>

                    <div class="card-body">

                        <form action="/listings" method="POST" enctype="multipart/form-data" novalidate
                            class="needs-validation">

                            <!-- TITLE -->

                            <div class="mb-3">
                                <label>Title</label>

                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-card-text"></i>
                                    </span>

                                    <input type="text" class="form-control" name="listing[title]" required>
                                </div>
                            </div>


                            <!-- DESCRIPTION -->

                            <div class="mb-3">
                                <label>Description</label>

                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-text-paragraph"></i>
                                    </span>

                                    <textarea class="form-control" rows="3" name="listing[description]"
                                        required></textarea>
                                </div>
                            </div>


                            <!-- CATEGORY -->

                            <div class="mb-3">
                                <label>Category</label>

                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-grid"></i>
                                    </span>

                                    <select class="form-select" name="listing[category]" required>

                                        <option value="">Choose category...</option>
                                        <option>Rooms</option>
                                        <option>Beachfront</option>
                                        <option>Pools</option>
                                        <option>Boat House</option>
                                        <option>Castles</option>
                                        <option>Golfing</option>
                                        <option>Iconic Cities</option>
                                        <option>Palaces</option>

                                    </select>

                                </div>
                            </div>


                            <!-- PRICE + LOCATION -->

                            <div class="row">

                                <div class="col-md-4 mb-3">
                                    <label>Price</label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-currency-rupee"></i>
                                        </span>

                                        <input type="number" class="form-control" name="listing[price]" required>
                                    </div>
                                </div>


                                <div class="col-md-8 mb-3">
                                    <label>Location</label>

                                    <div class="input-group">
                                        <span class="input-group-text">
                                            <i class="bi bi-geo-alt"></i>
                                        </span>

                                        <input type="text" class="form-control" name="listing[location]" required>
                                    </div>
                                </div>

                            </div>


                            <!-- COUNTRY -->

                            <div class="mb-3">
                                <label>Country</label>

                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-globe"></i>
                                    </span>

                                    <input type="text" class="form-control" name="listing[country]" required>
                                </div>
                            </div>


                            <!-- IMAGE -->

                            <div class="mb-3">
                                <label>Upload Image</label>

                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-image"></i>
                                    </span>

                                    <input type="file" class="form-control" name="image">
                                </div>
                            </div>


                            <!-- BUTTONS -->

                            <div class="d-flex justify-content-between mt-4">

                                <button class="btn btn-danger">
                                    <i class="bi bi-check-circle me-1"></i>
                                    Add
                                </button>

                                <a href="/listings" class="btn btn-outline-dark">
                                    Cancel
                                </a>

                            </div>

                        </form>

                    </div>
                </div>

            </div>

        </div>
    </div>