<% layout('/layouts/boilerplate') %>

    <style>
        .price-card {
            border-radius: 16px;
            border: 1px solid #e5e5e5;
            padding: 20px;
        }

        .listing-img {
            width: 100px;
            height: 90px;
            object-fit: cover;
            border-radius: 12px;
        }

        .price-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .total-price {
            font-size: 18px;
            font-weight: 600;
        }

        .booking-box {
            border: 1px solid #ddd;
            border-radius: 12px;
            overflow: hidden;
        }

        .booking-box input,
        .booking-box select {
            border: none;
            width: 100%;
            padding: 10px;
        }

        .booking-box label {
            font-size: 12px;
            font-weight: 600;
        }

        .rare-box {
            background: #f3e7eb;
            border-radius: 14px;
            font-weight: 500;
        }
    </style>


    <div class="container mt-5">

        <div class="row g-4">

            <!-- LEFT SIDE -->
            <div class="col-lg-7">

                <h2 class="mb-4">Confirm your booking</h2>

                <form action="/create-checkout-session/<%= listing._id %>" method="POST">

                    <div class="booking-box">

                        <div class="row g-0">

                            <div class="col-6 border-end p-2">

                                <label>CHECK-IN</label>
                                <input type="date" name="checkIn" id="checkin" required>

                            </div>

                            <div class="col-6 p-2">

                                <label>CHECK-OUT</label>
                                <input type="date" name="checkOut" id="checkout" required>

                            </div>

                        </div>

                        <div class="border-top p-2">

                            <label>GUESTS</label>

                            <select name="guests" id="guests">
                                <option value="1">1 guest</option>
                                <option value="2">2 guests</option>
                                <option value="3">3 guests</option>
                                <option value="4">4 guests</option>
                                <option value="5">5 guests</option>
                            </select>

                        </div>

                    </div>

                    <button  onclick="confirmBooking()" class="btn btn-danger w-100 mt-4 rounded-pill py-2">
                        Confirm & Pay
                    </button>

                </form>

            </div>


            <!-- RIGHT SIDE -->
            <div class="col-lg-5 mb-4 ">

                <div class="price-card">

                    <!-- Listing -->
                    <div class="d-flex mb-3">

                        <img src="<%= listing.image.url %>" class="listing-img me-3">

                        <div>
                            <h5 class="mb-1">
                                <%= listing.title %>
                            </h5>

                            <small class="text-muted">
                                ⭐ 4.92 (174) · Guest favourite
                            </small>
                        </div>

                    </div>

                    <hr>

                    <!-- Free Cancellation -->
                    <h6 class="fw-bold">Free cancellation</h6>

                    <p class="text-muted small mb-2">
                        Cancel anytime before check-in for a full refund.
                        <br>
                        <a href="#" class="text-dark fw-semibold">Full policy</a>
                    </p>

                    <hr>

                    <!-- Dates -->
                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <div>
                            <h6 class="fw-bold mb-0">Dates</h6>
                            <small class="text-muted" id="dateDisplay">
                                Select dates
                            </small>
                        </div>

                        <button class="btn btn-light btn-sm" onclick="focusDates()" type="button">
                            Change
                        </button>

                    </div>

                    <hr>

                    <!-- Guests -->
                    <div class="d-flex justify-content-between align-items-center mb-3">

                        <div>
                            <h6 class="fw-bold mb-0">Guests</h6>
                            <small class="text-muted" id="guestDisplay">
                                1 guest
                            </small>
                        </div>

                        <button class="btn btn-light btn-sm" onclick="focusGuests()" type="button">
                            Change
                        </button>

                    </div>

                    <hr>

                    <!-- Price details -->
                    <h6 class="fw-bold">Price details</h6>

                    <div class="price-row">
                        <span id="price">₹<%= listing.price %> × <span id="nights">0</span> nights</span>
                        <span id="subtotal">₹0</span>
                    </div>

                    <div class="price-row">
                        <span>Taxes</span>
                        <span id="tax">₹0</span>
                    </div>

                    <hr>

                    <div class="price-row total-price">
                        <span>Total INR</span>
                        <span id="total">₹0</span>
                    </div>

                </div>


            </div>

        </div>

    </div>


    <script>

        const price = <%= listing.price %>;

        const checkin = document.getElementById("checkin");
        const checkout = document.getElementById("checkout");
        const guests = document.getElementById("guests");

        const nightsEl = document.getElementById("nights");
        const subtotalEl = document.getElementById("subtotal");
        const taxEl = document.getElementById("tax");
        const totalEl = document.getElementById("total");

        const dateDisplay = document.getElementById("dateDisplay");
        const guestDisplay = document.getElementById("guestDisplay");

        function calculate() {

            if (!checkin.value || !checkout.value) return;

            const start = new Date(checkin.value);
            const end = new Date(checkout.value);

            const diff = (end - start) / (1000 * 60 * 60 * 24);

            if (diff <= 0) return;

            const subtotal = diff * price;
            const tax = subtotal * 0.1;
            const total = subtotal + tax;

            nightsEl.innerText = diff;
            subtotalEl.innerText = "₹" + subtotal;
            taxEl.innerText = "₹" + Math.round(tax);
            totalEl.innerText = "₹" + Math.round(total);

            dateDisplay.innerText = checkin.value + " – " + checkout.value;

        }

        function focusDates() {
            checkin.focus();
        }

        function focusGuests() {
            guests.focus();
        }

        guests.addEventListener("change", () => {
            guestDisplay.innerText = guests.value + " guest";
        });

        checkin.addEventListener("change", calculate);
        checkout.addEventListener("change", calculate);

    </script>