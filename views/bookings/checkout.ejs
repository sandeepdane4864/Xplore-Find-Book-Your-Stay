<% layout('/layouts/boilerplate') %>

    <div class="container mt-5 mb-5">
        <div class="row g-4">

            <!-- Booking Column -->
            <div class="col-lg-7">
                <div class="booking-box p-4 shadow-sm rounded">

                    <h3 class="mb-4">Confirm your booking</h3>

                    <!-- Stripe checkout form -->
                    <form id="checkout-form" action="/create-checkout-session/<%= listing._id %>" method="POST">

                        <label for="checkin">CHECK-IN</label>
                        <input type="date" name="checkIn" id="checkin" required>

                        <label for="checkout">CHECK-OUT</label>
                        <input type="date" name="checkOut" id="checkout" required>

                        <label for="guests">GUESTS</label>
                        <select name="guests" id="guests">
                            <option value="1">1 guest</option>
                            <option value="2">2 guests</option>
                            <option value="3">3 guests</option>
                            <option value="4">4 guests</option>
                            <option value="5">5 guests</option>
                        </select>

                        <button type="submit" class="btn-confirm mt-3 w-100">Confirm & Pay</button>
                    </form>

                </div>
            </div>

            <!-- Price Summary Column -->
            <div class="col-lg-5">
                <div class="price-card p-4 shadow-sm rounded">

                    <div class="d-flex mb-3">
                        <img src="<%= listing.image.url %>" class="listing-img me-3">
                        <div>
                            <h5 class="mb-1">
                                <%= listing.title %>
                            </h5>
                            <small class="text-muted">⭐ 4.92 · Guest favourite</small>
                        </div>
                    </div>

                    <hr>

                    <div class="summary-header fw-bold mb-2">Dates & Guests</div>
                    <p id="summaryDates">Select dates</p>
                    <p id="summaryGuests">1 guest</p>

                    <hr>

                    <div class="summary-header fw-bold mb-2">Price details</div>
                    <div class="price-row d-flex justify-content-between mb-2">
                        <span id="priceDetail">₹<%= listing.price %> × <span id="nights">0</span> nights</span>
                        <span id="subtotal">₹0</span>
                    </div>
                    <div class="price-row d-flex justify-content-between mb-2">
                        <span>Taxes</span>
                        <span id="tax">₹0</span>
                    </div>
                    <hr>
                    <div class="price-row d-flex justify-content-between total-price fw-bold">
                        <span>Total INR</span>
                        <span id="total">₹0</span>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <style>
        .booking-box input,
        .booking-box select {
            width: 100%;
            padding: 12px;
            margin: 5px 0 15px;
            border-radius: 12px;
            border: 1px solid #ddd;
        }

        .btn-confirm {
            background: #ff385c;
            color: white;
            font-weight: 600;
            border-radius: 50px;
            padding: 12px;
            font-size: 16px;
            border: none;
        }

        .btn-confirm:hover {
            background: #e61e4d;
        }

        .listing-img {
            width: 80px;
            height: 80px;
            border-radius: 12px;
            object-fit: cover;
        }

        .price-card,
        .booking-box {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        }

        @media(max-width:768px) {

            .col-lg-7,
            .col-lg-5 {
                flex: 0 0 100%;
                max-width: 100%;
                margin-bottom: 20px;
            }
        }
    </style>

    <script>
        const pricePerNight = <%= listing.price %>;

        const checkin = document.getElementById("checkin");
        const checkout = document.getElementById("checkout");
        const guests = document.getElementById("guests");
        const checkoutForm = document.getElementById("checkout-form");

        const nightsEl = document.getElementById("nights");
        const subtotalEl = document.getElementById("subtotal");
        const taxEl = document.getElementById("tax");
        const totalEl = document.getElementById("total");

        const summaryDates = document.getElementById("summaryDates");
        const summaryGuests = document.getElementById("summaryGuests");

        // Set minimum check-in date to today
        const today = new Date().toISOString().split("T")[0];
        checkin.setAttribute("min", today);

        // Update checkout min dynamically
        checkin.addEventListener("change", () => {
            const checkinDate = new Date(checkin.value);
            checkout.value = "";
            checkout.setAttribute("min", checkin.value);
            calculate();
        });

        checkout.addEventListener("change", () => {
            const checkinDate = new Date(checkin.value);
            const checkoutDate = new Date(checkout.value);

            if (checkoutDate <= checkinDate) {
                alert("Check-out date must be after check-in.");
                checkout.value = "";
            } else {
                calculate();
            }
        });

        guests.addEventListener("change", () => {
            summaryGuests.innerText = guests.value + " guest" + (guests.value > 1 ? "s" : "");
        });

        // Validate dates before form submission
        checkoutForm.addEventListener("submit", (e) => {
            const checkinDate = new Date(checkin.value);
            const checkoutDate = new Date(checkout.value);
            const todayDate = new Date(today);

            if (checkinDate < todayDate) {
                e.preventDefault();
                alert("Check-in cannot be in the past.");
                return false;
            }

            if (checkoutDate <= checkinDate) {
                e.preventDefault();
                alert("Check-out date must be after check-in.");
                return false;
            }
        });

        function calculate() {
            if (!checkin.value || !checkout.value) return;

            const start = new Date(checkin.value);
            const end = new Date(checkout.value);
            const diff = Math.ceil((end - start) / (1000 * 60 * 60 * 24));
            if (diff <= 0) return;

            const subtotal = diff * pricePerNight;
            const tax = Math.round(subtotal * 0.1);
            const total = subtotal + tax;

            nightsEl.innerText = diff;
            subtotalEl.innerText = "₹" + subtotal;
            taxEl.innerText = "₹" + tax;
            totalEl.innerText = "₹" + total;

            summaryDates.innerText = checkin.value + " – " + checkout.value;
        }
    </script>