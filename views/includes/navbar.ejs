<section>
  <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top shadow-sm mb-0">
    <div class="container">

      <!-- Logo -->
      <a href="/">
        <img src="/images/logo1.png" alt="logo" height="50" class="logo">
      </a>
      <a class="navbar-brand" href="/">Xplore</a>

      <!-- Mobile Toggle -->
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <!-- Navbar Content -->
      <div class="collapse navbar-collapse" id="mainNavbar">

        <!-- Left Links -->
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item">
            <a class="nav-link" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/listings">All Listings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/listings/new">Add New</a>
          </li>
        </ul>

        <!-- Mobile profile dropdown -->
        <% if(user){ %>
          <li class="nav-item dropdown d-lg-none mt-2">

            <a class="nav-link dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown">

              <img
                src="<%= user && user.profilePicture && user.profilePicture.url ? user.profilePicture.url : '/uploads/123.png' %>"
                width="40" height="40" class="rounded-circle border border-danger">

              <span>Hello, <%= user.firstName %></span>

            </a>

            <ul class="dropdown-menu">

              <li><a class="dropdown-item" href="/profile">Profile</a></li>
              <li><a class="dropdown-item" href="/settings">Settings</a></li>
              <li>
                <hr class="dropdown-divider">
              </li>
              <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>

            </ul>
          </li>
          <% } %>

            </ul>

            <!-- Center Search -->
            <form class="d-flex mx-auto my-3 my-lg-0" action="/listings" method="GET"
              style="max-width:350px;width:100%;">
              <input class="form-control rounded-pill me-2" type="search" name="q" placeholder="Search places">
              <button class="btn btn-danger rounded-pill px-3">
                <i class="bi bi-search"></i>
              </button>
            </form>

            <!-- Right Side -->
            <div class="d-flex align-items-center">

              <% if(!user){ %>

                <a href="/login" class="btn btn-outline-danger me-2">Login</a>
                <a href="/signup" class="btn btn-danger">Sign Up</a>

                <% } else { %>

                  <!-- Desktop profile dropdown -->
                  <div class="dropdown d-none d-lg-block">

                    <a class="d-flex align-items-center text-decoration-none dropdown-toggle" data-bs-toggle="dropdown">

                      <img
                        src="<%= (user.profilePicture && user.profilePicture.url) ? user.profilePicture.url : '/images/123.png' %>"
                        width="40" height="40" class="rounded-circle border border-danger">

                    </a>

                    <ul class="dropdown-menu dropdown-menu-end shadow">

                      <li>
                        <h6 class="dropdown-header">Hello, <%= user.firstName %>!</h6>
                      </li>

                      <li><a class="dropdown-item" href="/profile">Profile</a></li>
                      <li><a class="dropdown-item" href="/settings">Settings</a></li>

                      <li>
                        <hr class="dropdown-divider">
                      </li>

                      <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>

                    </ul>

                  </div>

                  <% } %>

            </div>

      </div>
    </div>
  </nav>

</section>