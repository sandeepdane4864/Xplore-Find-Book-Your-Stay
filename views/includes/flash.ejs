<div class="container mt-1 mb-0 mt-2">
    <div class="row justify-content-center">
        <div class="col-10 col-md-6 col-lg-6">

            <% if(success && success.length> 0){ %>
                <div class="alert alert-success alert-dismissible fade show small" role="alert" id="flash_success">
                    <%= success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
                <% } %>

                    <% if(error && error.length> 0){ %>
                        <div class="alert alert-danger alert-dismissible fade show small" role="alert" id="flash_error">
                            <%= error %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        <% } %>

        </div>
    </div>
</div>

<script>
    setTimeout(() => {
        let alerts = document.querySelectorAll(".alert");
        alerts.forEach(alert => {
            alert.remove();
        });
    }, 5500);
</script>