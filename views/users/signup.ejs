<% layout('/layouts/boilerplate') -%>

  <div class="container lists">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-11 col-md-9 col-lg-6 col-xl-5">

        <div class="card mb-4 mt-4 shadow-sm">
          <div class="card-header">
            <h3 class="mb-0">Create Account</h3>
          </div>

          <div class="card-body">

            <form action="/signup" method="POST" class="needs-validation" novalidate enctype="multipart/form-data">

              <!-- FIRST NAME -->
              <div class="mb-3">
                <label class="form-label">First Name</label>
                <input type="text" name="user[firstName]" class="form-control" required>
                <div class="invalid-feedback">
                  First name is required. Atlest 3 characters.
                </div>
              </div>

              <!-- LAST NAME -->
              <div class="mb-3">
                <label class="form-label">Last Name</label>
                <input type="text" name="user[lastName]" class="form-control" required>
                <div class="invalid-feedback">
                  Last name is required. Atlest 3 characters.
                </div>
              </div>

              <!-- USERNAME -->
              <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" name="user[username]" class="form-control" minlength="3" required>
                <div class="invalid-feedback">
                  Username must be combination of Alphabet, numbers and characters. Atlest 3 characters.
                </div>
              </div>

              <!-- EMAIL -->
              <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="user[email]" class="form-control" required>
                <div class="invalid-feedback">
                  Please enter a valid email address.
                </div>
              </div>

              <!-- PROFILE PICTURE -->
              <div class="mb-3">
                <label class="form-label">Profile Picture</label>
                <input type="file" name="profilePicture" accept="image/*" class="form-control">
              </div>

              <!-- PHONE -->
              <div class="mb-3">
                <label class="form-label">Phone Number</label>
                <input type="tel" name="user[phone_no]" class="form-control" pattern="[0-9]{10}" maxlength="10"
                  required>
                <div class="invalid-feedback">
                  Phone number must be exactly 10 digits.
                </div>
              </div>

              <!-- GENDER -->
              <div class="mb-3">
                <label class="form-label">Gender</label>
                <select name="user[gender]" class="form-select" required>
                  <option value="">Select Gender</option>
                  <option value="Male">Male</option>
                  <option value="Female">Female</option>
                  <option value="Other">Other</option>
                </select>
                <div class="invalid-feedback">
                  Please select your gender.
                </div>
              </div>

              <!-- DOB -->
              <div class="mb-3">
                <label class="form-label">Date of Birth</label>
                <input type="date" name="user[DOB]" class="form-control" required>
                <div class="invalid-feedback">
                  Date of birth is required.
                </div>
              </div>

              <!-- PASSWORD -->
              <div class="mb-3">
                <label class="form-label">Password</label>
                <div class="input-group">
                  <input type="password" name="user[password]" id="password" class="form-control" minlength="6"
                    required>
                  <button type="button" class="btn btn-outline-secondary" id="togglePassword">
                    <i class="bi bi-eye"></i>
                  </button>
                </div>
                <div class="invalid-feedback">
                  Password must be at least 6 characters.
                </div>
              </div>

              <!-- BUTTONS -->
              <div class="d-flex justify-content-between align-items-center">
                <button type="submit" class="btn btn-danger">
                  Register
                </button>

                <a href="/login" class="btn btn-outline-secondary">
                  Already have an account?
                </a>
              </div>

            </form>

          </div>
        </div>

      </div>
    </div>
  </div>